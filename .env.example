# Closed Care Loop deployment configuration
# The app works without these values by using deterministic Anthropic fallback
# and the mock EHR adapter.

# Anthropic tool-use agent
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# Optional OpenEMR FHIR reference adapter
# Leave blank to use the deterministic mock EHR.
OPENEMR_FHIR_BASE_URL=
OPENEMR_ACCESS_TOKEN=

# Keep false for demos. Enable only against a dedicated sandbox after testing.
OPENEMR_ALLOW_WRITES=false
